{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/inventory-system/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/inventory-system/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/inventory-system",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "catalog-service": {
      "type": "application",
      "root": "apps/catalog-service",
      "entryFile": "main",
      "sourceRoot": "apps/catalog-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/catalog-service/tsconfig.app.json"
      }
    },
    "iam-service": {
      "type": "application",
      "root": "apps/iam-service",
      "entryFile": "main",
      "sourceRoot": "apps/iam-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/iam-service/tsconfig.app.json"
      }
    },
    "inventory-service": {
      "type": "application",
      "root": "apps/inventory-service",
      "entryFile": "main",
      "sourceRoot": "apps/inventory-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/inventory-service/tsconfig.app.json"
      }
    },
    "procurement-service": {
      "type": "application",
      "root": "apps/procurement-service",
      "entryFile": "main",
      "sourceRoot": "apps/procurement-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/procurement-service/tsconfig.app.json"
      }
    },
    "sales-service": {
      "type": "application",
      "root": "apps/sales-service",
      "entryFile": "main",
      "sourceRoot": "apps/sales-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/sales-service/tsconfig.app.json"
      }
    }
  }
}